// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/debian
{
	"name": "Debian",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/base:trixie",

	// Features to add to the dev container. More info: https://containers.dev/features.
	"features": {
		//python feature
		"ghcr.io/devcontainers/features/python:1": {
			"installTools": true,
			"version": "latest",
			"tools": ["pip", "pipenv", "poetry"]
		},
		//docker outside
		"ghcr.io/devcontainers/features/docker-outside-of-docker:1":{
			"moby": false
		},
		//opencode feature
		"ghcr.io/devcontainers-extra/features/opencode:1": {},
		    "ghcr.io/siri404/devcontainer-ai-features/gemini-cli:1": {
        "version": "latest"
    },
		"ghcr.io/devcontainers/features/common-utils:2": {
			"installZsh": true,
			"configureZshAsDefaultShell": true,
			"installOhMyZsh": true,
			"installOhMyZshConfig": true,
			"upgradePackages": true
		},
		"ghcr.io/devcontainers-extra/features/zsh-plugins:0": {
			"plugins": "git git-flow F-Sy-H zsh-autosuggestions zsh-completions",
			"omzPlugins": "https://github.com/z-shell/F-Sy-H https://github.com/zsh-users/zsh-autosuggestions https://github.com/zsh-users/zsh-completions"
		},
		"ghcr.io/stuartleeks/dev-container-features/shell-history:0": {}
	}

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],

	// Configure tool-specific properties.
	// "customizations": {},

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
